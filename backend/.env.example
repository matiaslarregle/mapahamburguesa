 =============================================================================
# MapaHamburguesa — Variables de entorno
# Copiá este archivo a .env y completá con tus credenciales reales
# =============================================================================

# ---------- Supabase (REQUERIDO) ----------
SUPABASE_URL=https: 
SUPABASE_ANON_KEY= 
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Google OAuth (se configura en Supabase Auth Dashboard) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- JWT ----------
SECRET_KEY=cambiar-en-produccion-usar-secrets-token-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------- DigitalOcean Spaces (opcional) ----------
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=mapahamburguesa
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ---------- Resend (emails) ----------
RESEND_API_KEY=re_xxxxxxxxxxxx

# ---------- Gemini (asistente IA) ----------
GEMINI_API_KEY= 
GEMINI_MODEL=gemini-1.5-flash

# ---------- App ----------
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5500
CORS_ORIGINS=["http://localhost:5500","https://mapahamburguesa.com","https://www.mapahamburguesa.com"]

# =============================================================================
# Cloudflare Turnstile
# =============================================================================
# Site key: público, va en el frontend
CF_TURNSTILE_SITE_KEY=0x4AAAAAAA_TU_SITEKEY
# Secret key: PRIVADO, solo en backend
CF_TURNSTILE_SECRET_KEY=0x4AAAAAAA_TU_SECRETKEY
# En dev, dejar true. En prod, false (falla cerrado).
TURNSTILE_FAIL_OPEN=true
